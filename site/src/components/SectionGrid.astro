---
// Renders a resource collection as a card grid, optionally grouped by `format`.

import { getCollection, render } from "astro:content";
import Card from "./Card.astro";

interface Props {
  collection: "practice" | "tools" | "reading-list" | "events" | "community";
  formatOrder?: string[];
  groupHeadings?: Record<string, string>;
  limit?: number;
}

const { collection, formatOrder, groupHeadings = {}, limit } = Astro.props;

const entries = await getCollection(collection);
entries.sort(
  (a, b) =>
    (a.data.order ?? 999) - (b.data.order ?? 999) ||
    a.data.title.localeCompare(b.data.title),
);

const order =
  formatOrder ?? Array.from(new Set(entries.map((e) => e.data.format)));

const groups: { format: string; heading: string; items: typeof entries }[] = [];
for (const fmt of order) {
  const items = entries.filter((e) => e.data.format === fmt);
  if (items.length === 0) continue;
  const heading = groupHeadings[fmt] ?? fmt;
  groups.push({
    format: fmt,
    heading,
    items: limit ? items.slice(0, limit) : items,
  });
}

const rendered = await Promise.all(
  groups.flatMap((g) => g.items).map(async (entry) => {
    const { Content } = await render(entry);
    return [entry.id, Content] as const;
  }),
);
const bodyMap = new Map(rendered);
---

<div class="section-grid container">
  {groups.map((group) => (
    <section class="format-group">
      <h2 class="group-heading">
        {group.heading}
        <span class="count muted">({group.items.length})</span>
      </h2>
      <div class="grid">
        {group.items.map((entry) => {
          const Body = bodyMap.get(entry.id);
          return (
            <Card
              title={entry.data.title}
              format={entry.data.format}
              url={entry.data.url}
              venue={entry.data.venue}
              authors={entry.data.authors}
              year={entry.data.year}
              cluster={entry.data.cluster}
              topics={entry.data.topics}
              tags={entry.data.tags}
              missingProvenance={entry.data.missingProvenance}
              summary={entry.data.summary}
              embed={entry.data.embed}
              speakerImage={entry.data.speakerImage}
              speakerName={entry.data.speakerName}
            >
              {Body && <Body />}
            </Card>
          );
        })}
      </div>
    </section>
  ))}
</div>

<style>
  .section-grid {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }
  .format-group { display: flex; flex-direction: column; gap: 1rem; }
  .group-heading {
    font-family: var(--serif);
    font-size: 1.2rem;
    font-weight: 600;
    margin: 0;
    padding-bottom: .5rem;
    border-bottom: 1px solid var(--border);
    text-transform: capitalize;
  }
  .count { font-size: .9rem; font-weight: 400; }
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(18rem, 1fr));
    gap: 1rem;
  }
</style>
