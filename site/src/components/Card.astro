---
// Resource card for section pages.
// When `embed` is present the card renders a wide "hero" layout with an
// always-visible video player, a speaker portrait, and the summary above.
// Otherwise it renders the compact text-only card used elsewhere.

interface Props {
  title: string;
  format: string;
  url?: string;
  venue?: string;
  authors?: string;
  year?: number;
  cluster?: string;
  topics?: string[];
  tags?: string[];
  missingProvenance?: boolean;
  summary?: string;
  embed?: string;
  speakerImage?: string;
  speakerName?: string;
}

const {
  title, format, url, venue, authors, year,
  cluster, topics = [], tags = [],
  missingProvenance = false, summary, embed,
  speakerImage, speakerName,
} = Astro.props;

const formatLabel: Record<string, string> = {
  diagram: "Diagram", framework: "Framework", method: "Method", template: "Template",
  toolkit: "Toolkit", tool: "Tool", platform: "Platform",
  paper: "Paper", book: "Book", article: "Article", report: "Report",
  post: "Post", essay: "Essay",
  conference: "Conference", workshop: "Workshop", series: "Series", convening: "Convening",
  video: "Video", podcast: "Podcast", keynote: "Keynote", webinar: "Webinar",
  "conference-talk": "Talk",
  org: "Organization", program: "Program", degree: "Degree", person: "Person",
  event: "Event", institution: "Institution", "study-group": "Study group",
};

const isExpertConversation = tags.includes("expert-conversation");

// Extract a YouTube video ID from /embed/ID or watch?v=ID URLs so we can
// build a thumbnail fallback when no speaker portrait was curated.
function extractYouTubeId(value?: string): string | undefined {
  if (!value) return undefined;
  const embedMatch = value.match(/youtube\.com\/embed\/([A-Za-z0-9_-]{6,})/);
  if (embedMatch) return embedMatch[1];
  const watchMatch = value.match(/[?&]v=([A-Za-z0-9_-]{6,})/);
  if (watchMatch) return watchMatch[1];
  const shortMatch = value.match(/youtu\.be\/([A-Za-z0-9_-]{6,})/);
  if (shortMatch) return shortMatch[1];
  return undefined;
}

const ytId = extractYouTubeId(embed) ?? extractYouTubeId(url);
// hqdefault is always present (480x360); maxresdefault sometimes 404s.
const ytThumb = ytId ? `https://i.ytimg.com/vi/${ytId}/hqdefault.jpg` : undefined;

const heroImage = speakerImage ?? ytThumb;
const heroImageIsPortrait = Boolean(speakerImage); // curated portraits get square crop
const speakerLabel = speakerName ?? authors;

const isHero = Boolean(embed);
---

<article
  class:list={[
    "card",
    {
      "card--missing": missingProvenance,
      "card--conversation": isExpertConversation,
      "card--hero": isHero,
    },
  ]}
>
  <div class="card-meta">
    <span class="format-chip">{formatLabel[format] ?? format}</span>
    {isExpertConversation && <span class="conversation-chip">Expert conversation</span>}
    {cluster && <span class="cluster-chip">{cluster}</span>}
    {topics.slice(0, 2).map((t) => <span class="topic-chip">{t}</span>)}
    {missingProvenance && <span class="badge-missing">source unknown</span>}
  </div>

  {isHero ? (
    <div class="hero-header">
      {heroImage && (
        <div class:list={["hero-portrait", { "hero-portrait--square": heroImageIsPortrait }]}>
          <img src={heroImage} alt={speakerLabel ? `Portrait of ${speakerLabel}` : `Thumbnail for ${title}`} loading="lazy" />
        </div>
      )}
      <div class="hero-text">
        <h3 class="card-title">
          {url ? <a href={url} target="_blank" rel="noopener">{title}</a> : title}
        </h3>
        {(speakerLabel || venue || year) && (
          <p class="card-byline">
            {speakerLabel && <span class="byline-speaker">{speakerLabel}</span>}
            {speakerLabel && (venue || year) && <span class="sep"> · </span>}
            {venue && <span>{venue}</span>}
            {(venue && year) && <span class="sep"> · </span>}
            {year && <span>{year}</span>}
          </p>
        )}
        {summary && <p class="card-summary">{summary}</p>}
      </div>
    </div>
  ) : (
    <>
      <h3 class="card-title">
        {url ? <a href={url} target="_blank" rel="noopener">{title}</a> : title}
      </h3>
      {(authors || venue || year) && (
        <p class="card-byline">
          {authors && <span>{authors}</span>}
          {authors && (venue || year) && <span class="sep"> · </span>}
          {venue && <span>{venue}</span>}
          {(venue && year) && <span class="sep"> · </span>}
          {year && <span>{year}</span>}
        </p>
      )}
      {summary && <p class="card-summary">{summary}</p>}
    </>
  )}

  {embed && (
    <div class="embed-frame">
      <iframe
        src={embed}
        title={title}
        loading="lazy"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
        allowfullscreen
      />
    </div>
  )}

  <div class="card-body">
    <slot />
  </div>
</article>

<style>
  .card {
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 1rem 1.15rem;
    display: flex;
    flex-direction: column;
    gap: .5rem;
    transition: border-color .15s ease;
  }
  .card:hover { border-color: var(--accent); }
  .card--missing { border-left: 3px solid #c97a2c; }
  .card--conversation { border-left: 3px solid var(--accent-2); }

  /* Hero card: spans the full width of its grid row so the video and
     speaker portrait have room to breathe. */
  .card--hero {
    grid-column: 1 / -1;
    padding: 1.25rem 1.4rem 1.4rem;
    gap: .85rem;
  }

  .card-meta { display: flex; gap: .35rem; flex-wrap: wrap; align-items: center; }

  .format-chip, .cluster-chip, .topic-chip, .conversation-chip {
    font-family: var(--sans);
    font-size: .68rem;
    letter-spacing: .08em;
    text-transform: uppercase;
    padding: .15rem .45rem;
    border-radius: 2px;
  }
  .format-chip { color: var(--accent); background: var(--tint-warm); }
  .conversation-chip {
    color: var(--bg);
    background: var(--accent-2);
    letter-spacing: .04em;
  }
  .cluster-chip { color: var(--accent-2); background: #e8f4f6; letter-spacing: .03em; text-transform: none; }
  .topic-chip { color: var(--muted); background: var(--tint); }

  .badge-missing {
    font-family: var(--sans);
    font-size: .65rem;
    letter-spacing: .05em;
    text-transform: uppercase;
    color: #a84e12;
    background: #fef3e8;
    border: 1px dashed #d89a5e;
    padding: .12rem .4rem;
    border-radius: 2px;
  }

  .card-title {
    font-family: var(--serif);
    font-size: 1.05rem;
    font-weight: 600;
    line-height: 1.3;
    margin: 0;
  }
  .card-title a { color: var(--ink); border-bottom: 1px solid transparent; }
  .card-title a:hover { color: var(--accent); border-bottom-color: var(--accent); }
  .card--hero .card-title { font-size: 1.35rem; }

  .card-byline {
    font-family: var(--sans);
    font-size: .78rem;
    color: var(--muted);
    margin: 0;
  }
  .sep { margin: 0 .15rem; }
  .byline-speaker { color: var(--ink-soft); font-weight: 600; }

  .card-summary {
    font-family: var(--serif);
    font-size: .95rem;
    color: var(--ink-soft);
    line-height: 1.55;
    margin: 0;
    font-style: italic;
    max-width: 100%;
  }
  .card--hero .card-summary { font-style: normal; font-size: 1rem; }

  /* Hero header: portrait left, title/byline/summary right.
     Stacks on narrow viewports. */
  .hero-header {
    display: grid;
    grid-template-columns: 9rem 1fr;
    gap: 1.1rem;
    align-items: start;
  }
  @media (max-width: 640px) {
    .hero-header { grid-template-columns: 1fr; }
  }
  .hero-portrait {
    width: 100%;
    aspect-ratio: 16 / 9;
    background: #000;
    border-radius: 3px;
    overflow: hidden;
  }
  .hero-portrait--square { aspect-ratio: 1 / 1; }
  .hero-portrait img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .hero-text { display: flex; flex-direction: column; gap: .35rem; }

  .embed-frame {
    position: relative;
    padding-top: 56.25%; /* 16:9 */
    margin-top: .3rem;
    background: #000;
    border-radius: 3px;
    overflow: hidden;
  }
  .embed-frame iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }

  .card-body {
    font-size: .95rem;
    color: var(--ink-soft);
    line-height: 1.55;
  }
  .card-body :global(p) { margin: 0; }
  .card-body :global(p + p) { margin-top: .5rem; }
</style>
