---
// Field Notes index — practitioner posts in our voice.
import Base from "../layouts/Base.astro";
import { getCollection, render } from "astro:content";

const posts = (await getCollection("field-notes"))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const fmt = new Intl.DateTimeFormat("en-US", { dateStyle: "medium" });

// Pre-render MDX bodies so we can show them inline
const rendered = await Promise.all(
  posts.map(async (p) => {
    const { Content } = await render(p);
    return [p.id, Content] as const;
  }),
);
const bodyMap = new Map(rendered);
---

<Base title="Field Notes · Learning Engineering" active="field-notes">
  <header class="hero">
    <div class="container">
      <div class="eyebrow">Field Notes</div>
      <h1>Published ideas worth thinking about.</h1>
      <p class="subhead">
        Each note highlights a single principle, claim, or argument from the
        learning-engineering literature — with direct quotes, a pointer to the
        original, and a question for you to sit with.
      </p>
      <p class="grounding">
        <strong>Grounding.</strong> Every note cites a named source we've read. No
        practitioner-opinion filler, no fabricated examples. If a note can't
        point to a published piece, it doesn't belong here.
      </p>
    </div>
  </header>

  <div class="container notes-list">
    {posts.map((post) => {
      const Body = bodyMap.get(post.id);
      return (
        <article class="note">
          <div class="note-meta">
            <time datetime={post.data.date.toISOString()}>{fmt.format(post.data.date)}</time>
            {post.data.tags.slice(0, 3).map((t) => <span class="tag">{t}</span>)}
          </div>
          <h2 class="note-title">{post.data.title}</h2>
          <p class="note-summary">{post.data.summary}</p>
          <div class="note-body">
            {Body && <Body />}
          </div>
        </article>
      );
    })}

    {posts.length === 0 && (
      <p class="empty">No notes yet — check back soon.</p>
    )}
  </div>
</Base>

<style>
  .hero { background: var(--tint); border-bottom: 1px solid var(--border); }
  .hero .container { padding-top: 3rem; padding-bottom: 2rem; }
  .subhead {
    font-size: 1.05rem;
    color: var(--ink-soft);
    max-width: 36rem;
  }
  .grounding {
    font-family: var(--sans);
    font-size: .85rem;
    color: var(--muted);
    max-width: 36rem;
    line-height: 1.55;
    padding: .8rem 1rem;
    border-left: 2px solid var(--accent-2);
    background: var(--bg);
    margin-top: 1rem;
  }
  .grounding strong { color: var(--accent-2); font-weight: 600; }

  .notes-list { display: flex; flex-direction: column; gap: 0; }

  .note {
    padding: 2.5rem 0;
    border-bottom: 1px solid var(--border);
    max-width: 40rem;
  }
  .note:last-child { border-bottom: none; }

  .note-meta {
    display: flex;
    gap: .6rem;
    align-items: baseline;
    font-family: var(--sans);
    font-size: .75rem;
    color: var(--muted);
    margin-bottom: .6rem;
    letter-spacing: .02em;
  }
  .note-meta time { font-weight: 500; }
  .tag {
    font-size: .68rem;
    letter-spacing: .08em;
    text-transform: uppercase;
    color: var(--accent);
    background: var(--tint-warm);
    padding: .15rem .45rem;
    border-radius: 2px;
  }

  .note-title {
    font-family: var(--serif);
    font-size: 1.6rem;
    font-weight: 600;
    line-height: 1.2;
    margin: 0 0 .6rem 0;
    letter-spacing: -0.005em;
  }
  .note-summary {
    font-family: var(--serif);
    font-size: 1.05rem;
    font-style: italic;
    color: var(--ink-soft);
    margin-bottom: 1.2rem;
    max-width: 36rem;
  }
  .note-body { font-size: 1rem; line-height: 1.7; }
  .note-body :global(h2) {
    font-size: 1.2rem;
    font-weight: 600;
    margin-top: 1.8rem;
    margin-bottom: .6rem;
  }
  .note-body :global(h3) {
    font-size: 1.05rem;
    font-weight: 600;
    margin-top: 1.4rem;
    margin-bottom: .5rem;
  }
  .note-body :global(ul), .note-body :global(ol) {
    margin: 0 0 1em 1.4rem;
    padding: 0;
  }
  .note-body :global(li) { margin-bottom: .4em; max-width: 36rem; }
  .note-body :global(strong) { color: var(--ink); }

  .empty {
    color: var(--muted);
    font-style: italic;
    padding: 3rem 0;
  }
</style>
