---
// Shared page shell: metadata, global styles, nav, footer.
import NavBar from "../components/NavBar.astro";

interface Props {
  title: string;
  description?: string;
  active?: string;
}

const {
  title,
  description = "A practice-centered guide to learning engineering, anchored on IEEE ICICLE.",
  active,
} = Astro.props;

const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href={base + "favicon.svg"} />
  </head>
  <body>
    <NavBar active={active} />
    <main>
      <slot />
    </main>
    <footer>
      <div class="footer-inner">
        <div class="footer-brand">
          <strong>Learning Engineering</strong>
          <span class="muted"> · a practice-centered guide</span>
        </div>
        <nav class="footer-links" aria-label="Footer">
          <a href={base + "about/"}>About this site</a>
          <a href="https://sagroups.ieee.org/icicle/" target="_blank" rel="noopener">IEEE ICICLE</a>
        </nav>
      </div>
    </footer>

    <style is:global>
      :root {
        --bg:        #fefdf8;
        --ink:       #1a1d1a;
        --ink-soft:  #2d312d;
        --muted:     #6b6f6a;
        --accent:    #7a4e22;
        --accent-2:  #2c5f6f;
        --border:    #e4e0d7;
        --tint:      #f7f4ec;
        --tint-warm: #f4ebdc;

        --serif: "Charter", "Iowan Old Style", Georgia, "Times New Roman", serif;
        --sans:  -apple-system, BlinkMacSystemFont, "Inter", "Helvetica Neue", Arial, sans-serif;
        --mono:  ui-monospace, SFMono-Regular, "SF Mono", Menlo, Consolas, monospace;

        --measure: 38rem;
        --page-pad: clamp(1rem, 4vw, 2.5rem);
      }

      *, *::before, *::after { box-sizing: border-box; }
      html, body { margin: 0; padding: 0; }
      html { overflow-x: hidden; }
      body {
        background: var(--bg);
        color: var(--ink);
        font-family: var(--serif);
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
        text-rendering: optimizeLegibility;
      }

      img, svg, video { max-width: 100%; height: auto; }
      h1, h2, h3, h4, p, li, blockquote { overflow-wrap: break-word; }

      a { color: var(--accent); text-decoration: none; border-bottom: 1px solid transparent; transition: border-color .15s ease; }
      a:hover { border-bottom-color: var(--accent); }

      main { min-height: calc(100vh - 120px); padding-bottom: 4rem; }

      h1, h2, h3, h4 {
        font-family: var(--serif);
        font-weight: 600;
        line-height: 1.2;
        color: var(--ink);
        margin: 0 0 .6em 0;
      }
      h1 { font-size: clamp(2rem, 5vw, 3rem); letter-spacing: -0.01em; }
      h2 { font-size: clamp(1.4rem, 3vw, 1.8rem); }
      h3 { font-size: 1.15rem; font-weight: 600; }

      p { margin: 0 0 1em 0; max-width: var(--measure); }
      .muted { color: var(--muted); }

      .eyebrow {
        font-family: var(--sans);
        font-size: .75rem;
        letter-spacing: .18em;
        text-transform: uppercase;
        color: var(--accent);
        margin: 0 0 1rem 0;
      }

      .container {
        max-width: 60rem;
        margin: 0 auto;
        padding: 2.5rem var(--page-pad);
      }

      .container-wide {
        max-width: 72rem;
        margin: 0 auto;
        padding: 2.5rem var(--page-pad);
      }

      hr.rule {
        border: none;
        border-top: 1px solid var(--border);
        margin: 2.5rem 0;
      }

      footer {
        border-top: 1px solid var(--border);
        background: var(--tint);
        margin-top: 4rem;
      }
      .footer-inner {
        max-width: 72rem;
        margin: 0 auto;
        padding: 1.25rem var(--page-pad);
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
        flex-wrap: wrap;
        font-family: var(--sans);
        font-size: .85rem;
      }
      .footer-brand strong { font-family: var(--serif); font-weight: 600; }
      .footer-links { display: flex; gap: 1.2rem; }
      .footer-links a { color: var(--muted); border: none; }
      .footer-links a:hover { color: var(--accent); }
    </style>
  </body>
</html>
